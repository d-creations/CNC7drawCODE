@startuml

skinparam nodesep 60
skinparam ranksep 70
left to right direction

package "Core" {
    class CNC3drawCODE
    class Config
    class DrawBoard
}

package "Views / Controllers" {
    class View3d
    class Camera
    class MouseControl
    class KeyboardManager
    class CommandRegistry
    class CommandPanel
    class PropertyEditor
    class LetterDrawer
}

package "Constraints & Math" {
    class ConstraintSystem
    class GCS
    class Geometry
    class BaseNonLinearSolver
}

package "Storage" {
    class BaseStorage
    class LocalSketchStorage
    class HistoryManager
    class ClipboardManager
}

package "Renderers (View)" {
    class CanvasRenderer
    class HitTester
}

package "Tools" {
    class BaseTool
    class PointTool
    class LineTool
    class Circle3PTool
    class Circle2T1RTool
    class Circle3TTool
    class Arc3PTool
    class ArcCenterTool
    class LengthMeasurementTool
    class AngleMeasurementTool
    class RadiusMeasurementTool
    class HorizontalMeasurementTool
    class VerticalMeasurementTool
}

package "Shapes (Domain Model)" {
        class BaseShape
        class Point
        class DrawLine
        class DrawCircle
        class DrawArc
        class BaseMeasurementShape
        class AngleMeasurementShape
        class HorizontalMeasurementShape
        class LengthMeasurementShape
        class RadiusMeasurementShape
        class VerticalMeasurementShape
        note right of BaseShape
            Pure data/logic objects
            No rendering or camera dependencies
        end note
}

' --- Usage & Instantiation Relationships (Where objects are used) ---

CNC3drawCODE --> DrawBoard : creates & owns (The Document)
CNC3drawCODE --> View3d : creates & owns (The GUI)

View3d o-- DrawBoard : observes & edits
View3d *-- Camera : creates & owns
View3d *-- MouseControl : creates & owns
View3d *-- PropertyEditor : creates & owns
View3d *-- CommandPanel : creates & owns
View3d *-- KeyboardManager : creates & owns

MouseControl --> DrawBoard : uses
MouseControl --> CommandRegistry : uses
MouseControl --> BaseTool : creates & uses

KeyboardManager --> MouseControl : uses
KeyboardManager --> DrawBoard : uses
KeyboardManager --> CommandRegistry : uses

CommandPanel --> MouseControl : uses
CommandPanel --> CommandRegistry : uses

DrawBoard --> Camera : uses
DrawBoard --> ConstraintSystem : creates & owns
DrawBoard -down-> LocalSketchStorage : creates & uses
DrawBoard -down-> HistoryManager : creates & uses
DrawBoard -down-> ClipboardManager : uses
DrawBoard --> Config : uses
DrawBoard --> LetterDrawer : uses

DrawBoard *-- CanvasRenderer : creates & owns
DrawBoard o-- BaseShape : stores and manages (drawObjects)
DrawBoard --> ConstraintSystem : creates & owns
DrawBoard --> LetterDrawer : uses

CanvasRenderer --> Camera : uses
CanvasRenderer --> BaseShape : requests Display List (IR) from
CanvasRenderer --> HitTester : uses for hit-testing

note right of CanvasRenderer
    Rendering is fully decoupled from domain model shapes.
    Consumes display lists from shapes.
end note
HitTester --> BaseShape : hit-test using display list
note right of HitTester
    Centralized hit-testing logic
    Operates on display list primitives
end note

ConstraintSystem *-- GCS : creates & uses
GCS --> BaseNonLinearSolver : uses
GCS --> Geometry : uses

HistoryManager --> LocalSketchStorage : uses internally

' --- Inheritance / Subclass Relationships ---

BaseStorage <|-- LocalSketchStorage

BaseShape <|-- Point
BaseShape <|-- DrawLine
BaseShape <|-- DrawCircle
BaseShape <|-- DrawArc
BaseShape <|-- BaseMeasurementShape

BaseMeasurementShape <|-- AngleMeasurementShape
BaseMeasurementShape <|-- HorizontalMeasurementShape
BaseMeasurementShape <|-- LengthMeasurementShape
BaseMeasurementShape <|-- RadiusMeasurementShape
BaseMeasurementShape <|-- VerticalMeasurementShape

' --- Inheritance / Subclass Relationships ---
BaseTool <|-- PointTool
BaseTool <|-- LineTool
BaseTool <|-- Circle3PTool
BaseTool <|-- Circle2T1RTool
BaseTool <|-- Circle3TTool
BaseTool <|-- Arc3PTool
BaseTool <|-- ArcCenterTool
BaseTool <|-- LengthMeasurementTool
BaseTool <|-- AngleMeasurementTool
BaseTool <|-- RadiusMeasurementTool
BaseTool <|-- HorizontalMeasurementTool
BaseTool <|-- VerticalMeasurementTool

@enduml
